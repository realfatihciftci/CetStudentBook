@model CetStudentBook.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>
<h3 class="text-danger">Are you sure you want to delete this?</h3>
<hr />

<div>
    <h4>Book Details</h4>
    <dl class="row mt-3">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Author</dt>
        <dd class="col-sm-9">@Model.Author</dd>

        <dt class="col-sm-3">Publish Date</dt>
        <dd class="col-sm-9">@Model.PublishDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Page Count</dt>
        <dd class="col-sm-9">@Model.PageCount</dd>

        <dt class="col-sm-3">Second Hand?</dt>
        <dd class="col-sm-9">@(Model.IsSecondHand ? "Yes" : "No")</dd>
    </dl>
    
    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete Permanently" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
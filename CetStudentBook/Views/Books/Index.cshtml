@model IEnumerable<CetStudentBook.Models.Book>

@{
    ViewData["Title"] = "Books List";
}

<h1>Books</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</p>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Author</th>
        <th>Publish Date</th>
        <th>Page Count</th>
        <th>Second Hand?</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr>
            <td colspan="6" class="text-center">No books found in the database.</td>
        </tr>
    }
    else
    {
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Author</td>
                <td>@item.PublishDate.ToShortDateString()</td>
                <td>@item.PageCount</td>
                <td>@(item.IsSecondHand ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>